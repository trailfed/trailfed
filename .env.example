# Copy to .env and edit. Never commit the real .env.

# Postgres — used by docker-compose.yml
POSTGRES_PASSWORD=trailfed_dev_only

# Public origin the server advertises in ActivityPub objects, WebFinger, NodeInfo.
# Dev default: Caddy listens on 8090. In production, set to your public URL.
PUBLIC_ORIGIN=http://localhost:8090
PUBLIC_API_ORIGIN=http://localhost:8090

# Centrifugo — match infra/centrifugo/config.json (generate real secrets for production!).
CENTRIFUGO_HMAC_SECRET=CHANGE_ME_centrifugo_dev_secret
CENTRIFUGO_API_KEY=CHANGE_ME_centrifugo_api_key
