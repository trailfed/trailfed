# Dev reverse proxy for trailfed — binds on :80 inside the container,
# exposed on host 127.0.0.1:8090 by docker-compose.
# For production with a real domain, swap :80 for your hostname and
# Caddy will provision TLS automatically via Let's Encrypt.

:80 {
    encode zstd gzip

    # API & federation endpoints → Fedify server
    @api path /.well-known/* /api/* /nodeinfo/* /actors/* /healthz
    handle @api {
        reverse_proxy server:3000
    }

    # Self-hosted PMTiles basemap. file_server handles HTTP byte-range
    # requests natively, which is what the PMTiles protocol needs.
    # The .pmtiles file is gitignored; see infra/pmtiles/README.md.
    handle_path /tiles/* {
        root * /srv/pmtiles
        header {
            Access-Control-Allow-Origin *
            Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
            Access-Control-Allow-Headers "Range"
            Access-Control-Expose-Headers "Content-Range, Content-Length, Accept-Ranges"
        }
        file_server
    }

    # Everything else → SvelteKit frontend
    handle {
        reverse_proxy web:5173
    }
}
