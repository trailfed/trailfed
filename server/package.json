{
  "name": "@trailfed/server",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "tsx src/db/migrate.ts",
    "import-pbf": "tsx scripts/import-pbf.ts",
    "db:generate": "drizzle-kit generate && node scripts/fix-postgis-types.mjs"
  },
  "dependencies": {
    "@fedify/fedify": "^1.3.0",
    "@fedify/hono": "^2.1.10",
    "@hono/node-server": "^2.0.0",
    "@node-rs/argon2": "^2.0.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "osm-pbf-parser-node": "^1.1.4",
    "pino": "^10.3.1",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
